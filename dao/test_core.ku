思 运行核心自检() {
    通过 = 真
    通过 = 通过 且 测试布尔()
    通过 = 通过 且 测试条件()
    通过 = 通过 且 测试遍历()
    通过 = 通过 且 测试循环()
    通过 = 通过 且 测试返回()
    通过 = 通过 且 测试字符串()
    通过 = 通过 且 测试字符串别名()
    通过 = 通过 且 测试字符串别名补齐()
    通过 = 通过 且 测试索引赋值()
    通过 = 通过 且 测试空值()
    通过 = 通过 且 测试否分支()
    通过 = 通过 且 测试嵌套调用()
    通过 = 通过 且 测试调用()
    通过 = 通过 且 测试列表()
    通过 = 通过 且 测试列表别名()
    通过 = 通过 且 测试列表别名补齐()
    通过 = 通过 且 测试字典()
    通过 = 通过 且 测试数学别名补齐()
    通过 = 通过 且 测试导入()
    通过 = 通过 且 测试捕()
    通过 = 通过 且 测试捕finally()
    通过 = 通过 且 测试试终无捕()
    通过 = 通过 且 测试网络()
    若 通过 {
        print("核心自检通过")
    } 否 {
        print("核心自检失败")
    }
    通过
}

// === 异常处理测试 ===

思 测试捕() {
    // 测试 试-捕：捕获错误并恢复
    结果 = 试 {
        抛 "测试错误"
    } 捕 错 {
        错
    }
    若 结果 == "测试错误" {
        print("通过：试-捕")
        真
    } 否 {
        print("失败：试-捕 未捕获到错误")
        假
    }
}

思 测试捕finally() {
    // 测试 试-捕-终：finally 总是执行
    计 = 0
    试 {
        抛 "忽略"
    } 捕 错 {
        计 = 1
    } 终 {
        计 = 计 + 10
    }
    若 计 == 11 {
        print("通过：试-捕-终")
        真
    } 否 {
        print("失败：试-捕-终 计=")
        print(计)
        假
    }
}

思 测试试终无捕() {
    // 测试 试-终：无 catch 时错误会穿透，但 finally 仍执行
    计 = 0
    抛出的 = 假
    试 {
        试 {
            抛 "穿透"
        } 终 {
            计 = 1
        }
    } 捕 错 {
        抛出的 = 真
    }
    若 计 == 1 且 抛出的 {
        print("通过：试-终 无捕")
        真
    } 否 {
        print("失败：试-终 无捕")
        假
    }
}

// === 网络测试 ===
引 "std/net" 别 网

思 测试网络() {
    // 测试 GET（用 httpbin.org）
    响应 = 网_取("https://httpbin.org/get")
    若 响应["是否成功"] {
        print("网络测试通过: GET OK")
        真
    } 否 {
        print("网络测试失败: GET 不通")
        假
    }
}
