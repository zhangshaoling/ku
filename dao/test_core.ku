// test_core.ku - 道语言核心自检
// 原则：纯汉语、小而稳，只测最重要的根基

引 "std/math" 别 数
引 "std/list" 别 列
引 "std/string" 别 文

思 测试布尔() {
    若 真 且 非 假 {
        print("通过：布尔")
        真
    } 否 {
        print("失败：布尔")
        假
    }
}

思 测试条件() {
    值 = 3
    若 值 > 1 {
        print("通过：条件")
        真
    } 否 {
        print("失败：条件")
        假
    }
}

思 测试遍历() {
    数列 = [1, 2, 3]
    总和 = 0
    遍 数 于 数列 {
        总和 = 总和 + 数
    }
    若 总和 == 6 {
        print("通过：遍历")
        真
    } 否 {
        print("失败：遍历")
        假
    }
}

思 测试循环() {
    计数 = 0
    总和 = 0
    当 计数 < 3 {
        总和 = 总和 + 计数
        计数 = 计数 + 1
    }
    若 总和 == 3 {
        print("通过：循环")
        真
    } 否 {
        print("失败：循环")
        假
    }
}

思 加一(数) { 数 + 1 }

思 返回五() {
    返 5
}

思 测试返回() {
    若 返回五() == 5 {
        print("通过：返回")
        真
    } 否 {
        print("失败：返回")
        假
    }
}

思 测试字符串() {
    文本 = "天书" + "道"
    连接文本 = 文_连接(["天书", "道"], "")
    若 文本 == "天书道" 且 连接文本 == "天书道" {
        print("通过：字符串")
        真
    } 否 {
        print("失败：字符串")
        假
    }
}

思 测试字符串别名() {
    分列 = 文_分割("甲,乙", ",")
    去后 = 文_去空白(" 天书 ")
    含有 = 文_包含("天书道", "书")
    替后 = 文_替换("天书", "书", "道")
    若 分列[0] == "甲" 且 分列[1] == "乙" 且 去后 == "天书" 且 含有 且 替后 == "天道" {
        print("通过：字符串别名")
        真
    } 否 {
        print("失败：字符串别名")
        假
    }
}

思 测试字符串别名补齐() {
    若 文_是否为空("") 且 文_非空("道") 且 文_截取("天书道", 0, 2) == "天书" 且 文_重复("道", 2) == "道道" 且 文_左填充("7", 3, "0") == "007" 且 文_开头是("天书道", "天") 且 文_结尾是("天书道", "道") 且 文_取字符("天书", 1) == "书" 且 文_反转文本("道书天") == "天书道" 且 文_是否数字("123") {
        print("通过：字符串别名补齐")
        真
    } 否 {
        print("失败：字符串别名补齐")
        假
    }
}

思 测试索引赋值() {
    数列 = [1, 2, 3]
