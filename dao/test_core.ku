思 测试列表() {
    原列 = [3, 1, 2]
    新列 = 列_排序(原列)
    若 新列[0] == 1 且 新列[2] == 3 {
        print("通过：列表")
        真
    } 否 {
        print("失败：列表")
        假
    }
}

思 测试列表别名() {
    原列 = [1, 2, 2, 3]
    反列 = 列_反转(原列)
    去重 = 列_唯一(原列)
    若 列_长度(原列) == 4 且 列_包含(原列, 3) 且 列_首项(原列) == 1 且 列_末项(原列) == 3 且 反列[0] == 3 且 去重[1] == 2 {
        print("通过：列表别名")
        真
    } 否 {
        print("失败：列表别名")
        假
    }
}

思 测试列表别名补齐() {
    拉 = 列_拉链([1, 2], ["甲", "乙"])
    枚 = 列_枚举(["甲", "乙"])
    切 = 列_切片([0, 1, 2, 3], 1, 3)
    平 = 列_展平([[1, 2], [3]])
    交 = 列_交错([1, 3], [2, 4])
    填 = 列_填充([1], 3, 0)
    旋 = 列_旋转([1, 2, 3], 1)
    若 拉[0][1] == "甲" 且 枚[1][0] == 1 且 列_计数([1, 1, 2], 1) == 2 且 列_最小值([3, 1, 2]) == 1 且 列_最大值([3, 1, 2]) == 3 且 切[1] == 2 且 平[2] == 3 且 交[2] == 3 且 填[2] == 0 且 旋[0] == 3 {
        print("通过：列表别名补齐")
        真
    } 否 {
        print("失败：列表别名补齐")
        假
    }
}

