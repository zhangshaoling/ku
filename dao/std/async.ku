// std/async.ku — 道语言并发标准库
// 道生一，一生二，二生三，三生万物。并行以行万事。

引 "std/list" 别 列

// === 并行执行 ===
// 并行(任务列表) → 结果列表
// 任务列表中的每个元素是一个无参函数名（字符串）
// 例：并行(["取网页甲", "取网页乙"])
思 并行(任务列表) {
    结果 = 并行执行(任务列表)
    结果
}

// === 同时启动（不等结果）===
// 起(任务列表) → 无返回值，任务在后台运行
思 起(任务列表) {
    并行执行(任务列表)
    空
}

// === 等待全部完成 ===
// 候(任务列表) → 结果列表（与并行同，但语义强调"等待"）
思 候(任务列表) {
    并行执行(任务列表)
}
