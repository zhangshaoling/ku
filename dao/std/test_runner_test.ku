// std/test_runner_test.ku — 用 test_runner 测试 test_runner 自己
// 自描述用例: 断言通过 = test_runner.ku 工作正常
//
// 用法:
//   dao_core --bootstrap demos/frontend_bootstrap.kub.json \
//       dao/std/test_runner.ku dao/std/test_runner_test.ku
//
// 约束: 道语言当前 C VM 的 import 别名 (引 ... 别 t) 不能直接用
//   t.函数名() 这种点号成员调用. 用法:
//   - import 别名机制只为命名空间隔离
//   - 调函数时直接用函数名 (无 t. 前缀)

思 测试_断言相等_数字() {
  断言_相等(1 + 1, 2, "1+1 应等于 2")
  断言_相等(0, 0, "0 应等于 0")
  断言_相等(-5, -5, "负数相等")
}

思 测试_断言相等_字符串() {
  断言_相等("道" + "语言", "道语言", "字符串拼接")
  断言_相等("", "", "空串相等")
}

思 测试_断言相等_列表() {
  断言_相等([1, 2, 3], [1, 2, 3], "列表按序相等")
}

思 测试_断言相等_失败被登记() {
  // 期望这次断言失败, 但失败本身要被登记
  断言_相等(1, 2, "应失败的用例, 不应中断")
}

思 测试_断言真() {
  断言_真(真, "真就是真")
  断言_真(1 == 1, "等式为真")
  断言_真([1, 2][0] == 1, "索引取值等式")
}

思 测试_断言假() {
  断言_假(假, "假就是假")
  断言_假(1 == 2, "不等式为假")
}

思 测试_断言不等() {
  断言_不等(1, 2, "1 不等于 2")
  断言_不等("a", "b", "字符串不等")
}

思 测试_断言近似() {
  断言_近似(0.1 + 0.2, 0.3, 0.001, "浮点近似")
  断言_近似(1.0, 1.0000001, 0.0001, "极小差异")
}

思 测试_断言长度() {
  断言_长度([1, 2, 3], 3, "三个元素")
  断言_长度([], 0, "空列表")
  断言_长度("道语言", 3, "三个汉字")
}

思 测试_断言包含() {
  断言_包含([1, 2, 3], 2, "列表包含 2")
  断言_包含(["a", "b", "c"], "b", "字符串列表包含")
}

思 测试_失败不中断后续() {
  // 第一次失败, 第二次成功, 第三次失败
  断言_相等(1, 2, "失败1")
  断言_相等(3, 3, "成功1")
  断言_相等(4, 5, "失败2")
}

// ── 注册全部测试 ──
tr_注册("测试_断言相等_数字", 测试_断言相等_数字)
tr_注册("测试_断言相等_字符串", 测试_断言相等_字符串)
tr_注册("测试_断言相等_列表", 测试_断言相等_列表)
tr_注册("测试_断言相等_失败被登记", 测试_断言相等_失败被登记)
tr_注册("测试_断言真", 测试_断言真)
tr_注册("测试_断言假", 测试_断言假)
tr_注册("测试_断言不等", 测试_断言不等)
tr_注册("测试_断言近似", 测试_断言近似)
tr_注册("测试_断言长度", 测试_断言长度)
tr_注册("测试_断言包含", 测试_断言包含)
tr_注册("测试_失败不中断后续", 测试_失败不中断后续)

// 跑 + 打印
跑并打印()
