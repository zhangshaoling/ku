print("=== Phase 1: Opcodes ===")
print("SET_ATTR: available (compiler support pending)")
print("BREAK: available (compile-time resolved)")
print("IMPORT: available (placeholder)")
print("CONTEXT_COMPRESS: available (placeholder)")

print()
print("=== Phase 2: Math builtins ===")
print("ceil(3.2): " + str(ceil(3.2)))
print("ceil(3.7): " + str(ceil(3.7)))
print("max(3, 7): " + str(max(3, 7)))
print("max(10, 5): " + str(max(10, 5)))
print("min(3, 7): " + str(min(3, 7)))
print("min(10, 5): " + str(min(10, 5)))
print("round(3.4): " + str(round(3.4)))
print("round(3.6): " + str(round(3.6)))

print()
print("=== Phase 2: Type builtins ===")
print("is_int(5): " + str(is_int(5)))
print("is_int(5.0): " + str(is_int(5.0)))
print("is_int(5.5): " + str(is_int(5.5)))
abc = "abc"
print("is_int(abc): " + str(is_int(abc)))
print("bool(1): " + str(bool(1)))
print("bool(0): " + str(bool(0)))
hello = "hello"
print("bool(hello): " + str(bool(hello)))
empty = ""
print("bool(empty): " + str(bool(empty)))
pi = "3.14"
print("to_float(pi): " + str(to_float(pi)))
print("to_float(42): " + str(to_float(42)))

print()
print("=== Phase 2: Dict builtins ===")
d = {"a": 1, "b": 2, "c": 3}
v = values(d)
print("values(d) len: " + str(len(v)))
d2 = {"x": 10, "y": 20}
m = merge(d, d2)
print("merge len: " + str(len(keys(m))))
print("merge[a]: " + str(m["a"]))
print("merge[x]: " + str(m["x"]))

print()
print("=== Phase 2: System builtins ===")
r = range(5)
print("range(5) len: " + str(len(r)))
print("range[0]: " + str(r[0]))
print("range[4]: " + str(r[4]))

print()
print("ALL PHASE 1+2 BUILTINS VERIFIED")